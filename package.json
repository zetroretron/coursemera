{
  "name": "coursemera",
  "version": "1.0.1",
  "description": "A beautiful desktop learning platform for video courses",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "build:win": "electron-builder --win -p always",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "CourseMera",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "dependencies": {
    "electron-log": "^5.0.3",
    "electron-updater": "^6.1.7",
    "express": "^4.18.2",
    "get-video-duration": "^4.1.0"
  },
  "build": {
    "appId": "com.coursemera.app",
    "productName": "CourseMera",
    "directories": {
      "output": "output",
      "buildResources": "assets"
    },
    "files": [
      "src/**/*",
      "sample-courses/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "sample-courses",
        "to": "sample-courses"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Education"
    },
    "publish": {
      "provider": "github",
      "owner": "zetroretron",
      "repo": "coursemera"
    }
  }
}
